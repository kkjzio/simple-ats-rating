# ATS Rating System - 环境变量配置模板
# 复制此文件为 .env 并根据实际情况修改配置

# ==================== 应用基础配置 ====================
APP_NAME=ATS Rating System
APP_VERSION=0.1.0
DEBUG=false

# ==================== MongoDB配置 ====================
# MongoDB连接地址
MONGODB_URL=mongodb://127.0.0.1:27017
# MongoDB认证用户名和密码，留空则不使用认证
MONGODB_USERNAME=
MONGODB_PASSWORD=

# MongoDB数据库名称
MONGODB_DB_NAME=ats_system

# MongoDB连接池配置
MONGODB_MAX_POOL_SIZE=10
MONGODB_MIN_POOL_SIZE=1

# ==================== JWT配置 ====================
# JWT密钥（生产环境必须修改为随机字符串）
# 可以使用以下命令生成: openssl rand -hex 32
JWT_SECRET_KEY=your-secret-key-change-this-in-production

# JWT加密算法
JWT_ALGORITHM=HS256

# JWT访问令牌过期时间（分钟）
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ==================== CORS配置 ====================
# 允许的CORS源（多个源用逗号分隔）
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# 是否允许携带凭证
CORS_ALLOW_CREDENTIALS=true

# 允许的HTTP方法（* 表示所有方法）
CORS_ALLOW_METHODS=*

# 允许的HTTP头（* 表示所有头）
CORS_ALLOW_HEADERS=*

# ==================== 日志配置 ====================
# 日志级别: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# ==================== 文件上传配置 ====================
# 最大上传文件大小（字节）10MB = 10485760
MAX_UPLOAD_SIZE=10485760

# 允许的文件扩展名（多个扩展名用逗号分隔）
ALLOWED_FILE_EXTENSIONS=.pdf,.doc,.docx

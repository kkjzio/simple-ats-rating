# ==================== Docker Compose 配置 ====================
# DockerHub 用户名（用于拉取镜像）
# DOCKERHUB_USERNAME=your-dockerhub-username
# 镜像版本标签，留空则使用 latest
TAG=latest
# 前端对外暴露端口
FRONTEND_PORT=3000

# ==================== MongoDB 配置 ====================
# 留空表示不启用认证（开发/测试环境）
MONGO_INITDB_ROOT_USERNAME=
MONGO_INITDB_ROOT_PASSWORD=

# ==================== 后端应用配置（透传给 backend 容器）====================
APP_NAME=ATS Rating System
DEBUG=false
ENABLE_DOCS=false

# MongoDB 连接（docker 内网固定地址）
MONGODB_URL=mongodb://mongodb:27017
MONGODB_USERNAME=
MONGODB_PASSWORD=
MONGODB_DB_NAME=ats_system
MONGODB_MAX_POOL_SIZE=10
MONGODB_MIN_POOL_SIZE=1

# JWT 配置（生产环境必须修改！）
# 生成方式: openssl rand -hex 32
JWT_SECRET_KEY=change-this-to-a-random-secret-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=1440

# CORS 配置
CORS_ORIGINS=["*"]
CORS_ALLOW_CREDENTIALS=true
CORS_ALLOW_METHODS=["*"]
CORS_ALLOW_HEADERS=["*"]

# 日志
LOG_LEVEL=INFO

# 文件上传
MAX_UPLOAD_SIZE=10485760
ALLOWED_FILE_EXTENSIONS=[".pdf",".doc",".docx"]
